# Leave VITE_API_BASE_URL empty to use relative paths (enables proxy).
VITE_API_BASE_URL=

# API prefix used by frontend service calls.
VITE_API_PREFIX=/api/v1

# Target backend URL for the Vite proxy to forward local requests to.
VITE_PROXY_TARGET=https://blog-backend-mueu.onrender.com

# Optional local ports.
VITE_DEV_PORT=5173
VITE_PREVIEW_PORT=4173